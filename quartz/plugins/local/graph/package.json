{
  "name": "graph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "scripts": {
    "build": "mkdir -p dist && cp index.js dist/index.js && printf 'export {}\n' > dist/index.d.ts"
  },
  "quartz": {
    "name": "graph",
    "displayName": "graph",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultEnabled": true,
    "defaultOptions": {
      "localGraph": {
        "showTags": false
      },
      "globalGraph": {
        "showTags": false
      }
    }
  }
}
